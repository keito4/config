      "Bash(~/.codex/sync-agents.sh:*)",
      "Bash(./script/*:*)",

      "Read(//.codex/**)",
      "Read(//.claude/plugins/**)",
      "Read(//home/vscode/**)",
      "Read(//tmp/**)",
      "Read(//workspaces/**)",

      "Skill(plugin-dev:command-development)",
      "Skill(vercel:logs)",
      "Skill(config-base-sync-update)"
    ],
    "deny": [
      "Bash(git push --force)",
      "Bash(git push --force:*)",
      "Bash(git push -f)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git reflog expire:*)",

      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf .)",
      "Bash(rm -rf ./)",
      "Bash(rm -rf .git)",
      "Bash(rm -rf .git:*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~:*)",

      "Bash(docker system prune:*)",
      "Bash(docker volume prune:*)",
      "Bash(docker run --privileged:*)",
      "Bash(docker push:*)",

