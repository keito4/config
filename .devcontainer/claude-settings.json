      "Bash(helm uninstall --purge:*)",

      "Bash(terraform destroy)",
      "Bash(terraform destroy:*)",
      "Bash(terraform apply -auto-approve:*)",
      "Bash(terraform state rm:*)",

      "Bash(aws ec2 terminate-instances:*)",
      "Bash(aws s3 rm --recursive:*)",
      "Bash(aws s3 rb:*)",
      "Bash(aws rds delete-db:*)",
      "Bash(aws cloudformation delete-stack:*)",
      "Bash(aws iam delete-role:*)",
      "Bash(aws iam delete-policy:*)",
      "Bash(aws iam delete-user:*)",
      "Bash(aws lambda delete-function:*)",

      "Bash(gcloud projects delete:*)",
      "Bash(gcloud compute instances delete:*)",
      "Bash(gcloud sql instances delete:*)",
      "Bash(gcloud container clusters delete:*)",

      "Bash(az group delete:*)",
      "Bash(az vm delete:*)",
      "Bash(az sql server delete:*)",
      "Bash(az storage account delete:*)",

      "Bash(supabase db push)",
      "Bash(supabase db push:*)",
      "Bash(npx supabase db push)",
      "Bash(npx supabase db push:*)",
      "Bash(supabase db reset)",
      "Bash(supabase db reset:*)",
      "Bash(npx supabase db reset)",
      "Bash(npx supabase db reset:*)",
      "Bash(supabase migration squash)",
      "Bash(supabase migration squash:*)",
      "Bash(npx supabase migration squash)",
      "Bash(npx supabase migration squash:*)",
      "Bash(supabase migration repair)",
      "Bash(supabase migration repair:*)",
      "Bash(npx supabase migration repair)",
      "Bash(npx supabase migration repair:*)",
      "Bash(supabase db branch delete)",
      "Bash(supabase db branch delete:*)",
      "Bash(npx supabase db branch delete)",
      "Bash(npx supabase db branch delete:*)",
      "Bash(supabase functions)",
      "Bash(supabase functions:*)",
      "Bash(supabase projects delete:*)",

      "Bash(vercel --prod)",
      "Bash(vercel --prod:*)",
      "Bash(vercel rm:*)",
      "Bash(vercel remove:*)",
      "Bash(vercel env rm:*)",

      "Bash(npm publish)",
      "Bash(npm publish:*)",
      "Bash(npm unpublish)",
      "Bash(npm unpublish:*)",

      "Bash(op item delete:*)",

      "mcp__plugin_supabase-toolkit_supabase__execute_sql",
      "mcp__supabase__execute_sql"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/vscode/.claude/hooks/block_dangerous_commands.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/vscode/.claude/hooks/block_git_no_verify.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/vscode/.claude/hooks/pre_git_quality_gates.py"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/vscode/.claude/hooks/pre_exit_plan_ai_review.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/vscode/.claude/hooks/post_git_push_ci.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/vscode/.claude/hooks/post_pr_ai_review.py"
          }
        ]
      }
    ]
  }
}
