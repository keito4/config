# DevContainer 環境変数テンプレート
# 1Password CLI により自動展開されます
# script/credentials.sh fetch により credentials/devcontainer.env に展開されます
# 必要な場合は ~/.devcontainer.env にコピーして使用します

# AWS Credentials
AWS_ACCESS_KEY_ID=op://Dev/AWS/AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=op://Dev/AWS/AWS_SECRET_ACCESS_KEY
AWS_REGION=op://Dev/AWS/AWS_REGION
