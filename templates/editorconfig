# EditorConfig
#
# エディタ間のコーディングスタイル一貫性を確保する
# 参考: https://editorconfig.org
#
# 使い方:
#   .editorconfig にコピーして配置
#
root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{go,py}]
indent_size = 4

[*.{yaml,yml}]
indent_size = 2
